# Tabs are better for semantics, accessibility and customization
UseTab: Always
IndentWidth: 4
TabWidth: 4

BinPackArguments: true
# TODO: Clang-Format 23
# Either place everthing on the same line or one per line
#PackParameters:
#  BinPack: OnePerLine

# Do not try to be cute with comments.
AlignTrailingComments:
  Kind: Never

# Visually call out when access modifier scope changes
IndentAccessModifiers: false
AccessModifierOffset: -4

# It is very buisy to have switch and cases on the same level
IndentCaseLabels: true

# Consistent intializers on new lines
PackConstructorInitializers: Never

# Visually indicate when in namespace
NamespaceIndentation: All
# Visual noise that does not improve readability
FixNamespaceComments: false
